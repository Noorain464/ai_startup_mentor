# =============================================================
#  Startup Idea Validator — environment configuration
#  Copy this file to `.env` and fill in your keys.
# =============================================================

# --- LLM provider -------------------------------------------------
# Choose "openai", "anthropic", or "openrouter".
LLM_PROVIDER=openrouter

# Optional explicit model override. Defaults:
#   openai     -> gpt-4o
#   anthropic  -> claude-sonnet-4-6
#   openrouter -> openai/gpt-4o   (must be a tool-calling-capable model)
# For OpenRouter use namespaced ids, e.g. openai/gpt-4o or anthropic/claude-3.5-sonnet
# LLM_MODEL=openai/gpt-4o

# OpenRouter (used when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Anthropic (used when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# --- Tools --------------------------------------------------------
# Tavily search (free tier ~1,000 searches/month). https://tavily.com
TAVILY_API_KEY=tvly-...

# --- Observability (LangSmith) ------------------------------------
# Set tracing on to auto-trace every graph run in the LangSmith UI.
LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=ls-...
LANGCHAIN_PROJECT=startup-idea-validator
